# Twilio account credentials.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Default sender in E.164 format, for example +12015551234.
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Optional Twilio Messaging Service SID. Required for scheduled sends.
TWILIO_MESSAGING_SERVICE_SID=

# Optional override for webhook signature validation.
# Leave blank to reuse TWILIO_AUTH_TOKEN.
TWILIO_WEBHOOK_AUTH_TOKEN=

# Set this when the app is behind a reverse proxy so signature validation
# uses the public HTTPS URL that Twilio calls.
TWILIO_PUBLIC_WEBHOOK_BASE_URL=

# Disable only for local debugging if you cannot reproduce the public URL.
TWILIO_VALIDATE_WEBHOOK_SIGNATURES=true

# Runtime tuning.
TWILIO_BULK_SEND_CONCURRENCY=10
TWILIO_LOG_LEVEL=INFO
TWILIO_DB_PATH=/data/inbox.db
WEBHOOK_PORT=8080

# Retry settings for transient Twilio API errors.
TWILIO_API_RETRY_ATTEMPTS=3
TWILIO_API_RETRY_DELAY=1.0
